  <folder name="Strategy" id="id-ee19737e69e64b28bc1879fc88e41e83" type="strategy"/>
  <folder name="Business" id="id-32b67a09915643c88297a2353c8d756a" type="business"/>
  <folder name="Application" id="id-10a55f0d122e47fb99244c8cee70f8d8" type="application"/>
  <folder name="Technology &amp; Physical" id="id-e988056491724a82a56b6cbe49b89af4" type="technology"/>
  <folder name="Motivation" id="id-25984f54132945399ed554fc15d2118c" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Human Clarity Stakeholder" id="id-el-1-HumanClarityStakeholder">
      <documentation>Human Clarity Stakeholder - A person or group with an interest in the architecture.</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Need for Mental Clarity" id="id-el-2-NeedforMentalClarity">
      <documentation>Need for Mental Clarity - A factor that motivates change (e.g., regulation, customer demand).</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="Human Confusion Assessment" id="id-el-3-HumanConfusionAssessment">
      <documentation>Human Confusion Assessment - An evaluation of a situation (e.g., SWOT, risk analysis).</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Improve Human Clarity" id="id-el-4-ImproveHumanClarity">
      <documentation>Improve Human Clarity - A long-term desired outcome (e.g.,Improve customer satisfaction).</documentation>
    </element>
    <element xsi:type="archimate:Outcome" name="Reduce Cognitive Overload" id="id-el-5-ReduceCognitiveOverload">
      <documentation>Reduce Cognitive Overload - A measurable end result (e.g.,Reduce call wait time to 30 seconds).</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Clarity-First Principle" id="id-el-6-Clarity-FirstPrinciple">
      <documentation>Clarity-First Principle - A rule or guideline that shapes decisions.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Framework Must Be Simple" id="id-el-7-FrameworkMustBeSimple">
      <documentation>Framework Must Be Simple - A need that must be met (e.g.,System must support 10k users).</documentation>
    </element>
    <element xsi:type="archimate:Constraint" name="Avoid Psychological Harm" id="id-el-8-AvoidPsychologicalHarm">
      <documentation>Avoid Psychological Harm - A limitation that must be respected (e.g., budget, compliance).</documentation>
    </element>
    <element xsi:type="archimate:Meaning" name="Meaning of Human Clarity" id="id-el-9-MeaningofHumanClarity">
      <documentation>Meaning of Human Clarity - The significance of an object or concept.</documentation>
    </element>
    <element xsi:type="archimate:Value" name="Value of Self-Understanding" id="id-el-10-ValueofSelf-Understanding">
      <documentation>Value of Self-Understanding - The benefit or importance of something to a stakeholder.</documentation>
    </element>
  </folder>
  <folder name="Implementation &amp; Migration" id="id-f05909bc20314dbd87c22274b7969a20" type="implementation_migration"/>
