<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Human Clarity Model" id="id-model-HCF" version="5.0.0">
  <folder name="Strategy" id="id-ee19737e69e64b28bc1879fc88e41e83" type="strategy">
    <element xsi:type="archimate:Capability" name="Clarity Awareness" id="id-cap-1-ClarityAwareness">
      <documentation>Ability to recognize when mental/emotional clarity is low or compromised.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="Emotional Regulation" id="id-cap-2-EmotionalRegulation">
      <documentation>Ability to notice, name, and modulate emotional states safely.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="Cognitive Organization" id="id-cap-3-CognitiveOrganization">
      <documentation>Ability to structure thoughts, tasks, and information coherently.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="Meaning Making" id="id-cap-4-MeaningMaking">
      <documentation>Ability to interpret experiences and patterns in a personally coherent way.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="Decision Clarity" id="id-cap-5-DecisionClarity">
      <documentation>Ability to make grounded, transparent decisions under emotional and cognitive load.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="Relational Clarity" id="id-cap-6-RelationalClarity">
      <documentation>Ability to understand and navigate interpersonal dynamics without confusion or projection.</documentation>
    </element>
    <element xsi:type="archimate:Capability" name="Decision Clarity" id="id-ta-capability"/>
  </folder>
  <folder name="Business" id="id-32b67a09915643c88297a2353c8d756a" type="business">
    <element xsi:type="archimate:BusinessActor" name="Human Clarity Stakeholder" id="id-bus-actor-1">
      <documentation>The primary stakeholder experiencing confusion, overload, or clarity.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Clarity Coach" id="id-bus-actor-2">
      <documentation>Supports the stakeholder in achieving clarity through structured interventions.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Clarity Support Role" id="id-bus-role-1">
      <documentation>Role responsible for delivering clarity‑enhancing services.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Assessment Role" id="id-bus-role-2">
      <documentation>Role responsible for evaluating confusion, overload, and clarity gaps.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Assess Confusion" id="id-bus-proc-1">
      <documentation>Evaluates emotional, cognitive, and behavioral confusion.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Deliver Clarity Intervention" id="id-bus-proc-2">
      <documentation>Provides structured clarity‑enhancing activities.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Monitor Clarity Progress" id="id-bus-proc-3">
      <documentation>Tracks clarity improvements over time.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Clarity Assessment Service" id="id-bus-svc-1">
      <documentation>Service that evaluates the stakeholder’s clarity state.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Clarity Improvement Service" id="id-bus-svc-2">
      <documentation>Service that delivers clarity‑enhancing interventions.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Clarity Assessment Service" id="id-ta-business-service"/>
  </folder>
  <folder name="Application" id="id-10a55f0d122e47fb99244c8cee70f8d8" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Clarity Assessment Application" id="id-app-1-ClarityAssessmentApp">
      <documentation>Supports assessment of emotional, cognitive, and behavioral confusion.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Clarity Intervention Application" id="id-app-2-ClarityInterventionApp">
      <documentation>Delivers structured clarity‑enhancing interventions and exercises.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Clarity Progress Tracker" id="id-app-3-ClarityProgressTracker">
      <documentation>Tracks clarity improvements and generates insights over time.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Assessment Processing Service" id="id-app-svc-1">
      <documentation>Processes assessment inputs and produces clarity scores.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Intervention Delivery Service" id="id-app-svc-2">
      <documentation>Delivers clarity‑enhancing content and exercises.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Progress Analytics Service" id="id-app-svc-3">
      <documentation>Analyzes clarity trends and generates insights.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Assessment Processing" id="id-app-func-1"/>
    <element xsi:type="archimate:ApplicationFunction" name="Intervention Execution" id="id-app-func-2"/>
    <element xsi:type="archimate:ApplicationFunction" name="Progress Analysis" id="id-app-func-3"/>
    <element xsi:type="archimate:DataObject" name="Assessment Data" id="id-data-1"/>
    <element xsi:type="archimate:DataObject" name="Intervention Content" id="id-data-2"/>
    <element xsi:type="archimate:DataObject" name="Clarity Progress Record" id="id-data-3"/>
    <element xsi:type="archimate:DataObject" name="Assessment Records" id="id-data-1-Assessments">
      <documentation>Structured records of emotional, cognitive, and behavioral assessments.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Intervention Library" id="id-data-2-Interventions">
      <documentation>Catalog of clarity‑enhancing interventions, exercises, and protocols.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Clarity Progress History" id="id-data-3-Progress">
      <documentation>Time‑series records of clarity scores and related metrics.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Stakeholder Profile" id="id-data-4-UserProfile">
      <documentation>Profile data for the Human Clarity Stakeholder (preferences, context, constraints).</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Clarity Configuration and Rules" id="id-data-5-ConfigRules">
      <documentation>Configuration, thresholds, and rules used by assessment and intervention logic.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Assessment Processing Service" id="id-ta-application-service"/>
    <element xsi:type="archimate:DataObject" name="Assessment Records" id="id-ta-data-object"/>
  </folder>
  <folder name="Technology &amp; Physical" id="id-e988056491724a82a56b6cbe49b89af4" type="technology">
    <element xsi:type="archimate:Node" name="Clarity Platform Server" id="id-tech-node-1">
      <documentation>Primary application server hosting assessment, intervention, and progress services.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Clarity Data Server" id="id-tech-node-2">
      <documentation>Database server storing assessments, interventions, and progress history.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Client Device" id="id-tech-node-3">
      <documentation>End‑user device accessing the Human Clarity applications.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Application Host VM" id="id-tech-dev-1">
      <documentation>Virtual machine or container running the Clarity Platform Server.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Database Host VM" id="id-tech-dev-2">
      <documentation>Virtual machine or container running the Clarity Data Server.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="User Laptop / Mobile" id="id-tech-dev-3">
      <documentation>Physical device used by the Human Clarity Stakeholder.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Application Runtime" id="id-tech-sw-1">
      <documentation>Web application runtime (e.g., application server / framework).</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Database Engine" id="id-tech-sw-2">
      <documentation>Relational or document database engine.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Client Browser / App Runtime" id="id-tech-sw-3">
      <documentation>Browser or mobile runtime used to access the Clarity applications.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Clarity Platform Server" id="id-ta-tech-node"/>
  </folder>
  <folder name="Motivation" id="id-25984f54132945399ed554fc15d2118c" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Human Clarity Stakeholder" id="id-el-1-HumanClarityStakeholder">
      <documentation>Human Clarity Stakeholder - A person or group with an interest in the architecture.</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Need for Mental Clarity" id="id-el-2-NeedforMentalClarity">
      <documentation>Need for Mental Clarity - A factor that motivates change (e.g., regulation, customer demand).</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="Human Confusion Assessment" id="id-el-3-HumanConfusionAssessment">
      <documentation>Human Confusion Assessment - An evaluation of a situation (e.g., SWOT, risk analysis).</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Improve Human Clarity" id="id-el-4-ImproveHumanClarity">
      <documentation>Improve Human Clarity - A long-term desired outcome (e.g.,Improve customer satisfaction).</documentation>
    </element>
    <element xsi:type="archimate:Outcome" name="Reduce Cognitive Overload" id="id-el-5-ReduceCognitiveOverload">
      <documentation>Reduce Cognitive Overload - A measurable end result (e.g.,Reduce call wait time to 30 seconds).</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Clarity-First Principle" id="id-el-6-Clarity-FirstPrinciple">
      <documentation>Clarity-First Principle - A rule or guideline that shapes decisions.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Framework Must Be Simple" id="id-el-7-FrameworkMustBeSimple">
      <documentation>Framework Must Be Simple - A need that must be met (e.g.,System must support 10k users).</documentation>
    </element>
    <element xsi:type="archimate:Constraint" name="Avoid Psychological Harm" id="id-el-8-AvoidPsychologicalHarm">
      <documentation>Avoid Psychological Harm - A limitation that must be respected (e.g., budget, compliance).</documentation>
    </element>
    <element xsi:type="archimate:Meaning" name="Meaning of Human Clarity" id="id-el-9-MeaningofHumanClarity">
      <documentation>Meaning of Human Clarity - The significance of an object or concept.</documentation>
    </element>
    <element xsi:type="archimate:Value" name="Value of Self-Understanding" id="id-el-10-ValueofSelf-Understanding">
      <documentation>Value of Self-Understanding - The benefit or importance of something to a stakeholder.</documentation>
    </element>
  </folder>
